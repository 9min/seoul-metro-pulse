{
	"compilerOptions": {
		"target": "ES2020",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"strict": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"noUncheckedIndexedAccess": true,
		"skipLibCheck": true,
		"isolatedModules": true,
		"esModuleInterop": true
	},
	"include": ["./**/*.ts"]
}
